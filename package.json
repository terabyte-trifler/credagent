{
  "name": "credagent",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "anchor test --skip-build",
    "test:integration": "anchor test --skip-build",
    "test:security": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json vitest run --globals tests/security/attack_vectors.ts tests/security/escrow_unauthorized.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "0.1.8",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/node": "^24.6.0",
    "chai": "^4.3.4",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
